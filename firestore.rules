rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Login page queries users by username (client-side auth — tighten for production)
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  
    // Dashboard reads/writes packages
    match /packages/{packageId} {
      allow read, write: if true;
    }
  }
}